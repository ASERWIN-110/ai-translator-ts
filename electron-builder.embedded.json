{
  "appId": "com.local.aitranslatorts.embedded",
  "productName": "AI Translator TS Embedded",
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "directories": {
    "output": "release-embedded"
  },
  "extraMetadata": {
    "name": "ai-translator-ts-embedded",
    "productName": "AI Translator TS Embedded",
    "desktopName": "ai-translator-ts-embedded",
    "main": "dist/electron-embedded-main.js"
  },
  "files": [
    "dist/**/*",
    "public/**/*",
    "data/**/*",
    "package.json",
    "README.md",
    "LICENSE",
    "docs/**/*"
  ],
  "linux": {
    "syncDesktopName": true,
    "category": "Utility",
    "target": [
      "AppImage"
    ]
  },
  "win": {
    "target": [
      "nsis",
      "zip"
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "mac": {
    "category": "public.app-category.utilities",
    "target": [
      "dmg",
      "zip"
    ]
  },
  "asarUnpack": [
    "public/**/*",
    "node_modules/node-llama-cpp/**/*",
    "node_modules/@node-llama-cpp/**/*"
  ]
}
